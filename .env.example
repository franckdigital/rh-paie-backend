# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production-use-50-chars-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.ci

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=rhpaie
DB_USER=rhpaie
DB_PASSWORD=mot_de_passe_securise
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Email SMTP ────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=mot_de_passe_application_google
DEFAULT_FROM_EMAIL=RH Paie <noreply@rhpaie.ci>

# ── CORS (séparer par virgule) ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://votre-domaine.ci
